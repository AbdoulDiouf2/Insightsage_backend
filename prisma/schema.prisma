// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(255)
  sector     String?  @db.VarChar(100)
  size       String   @default("pme") // taille entreprise: "startup" | "pme" | "business" | "enterprise"
  country    String?  // pays de l'organisation (step 2 onboarding)
  sageType   String? // "X3" | "100"
  sageMode   String? // "local" | "cloud" (step 3 onboarding)
  sageHost   String?
  sagePort   Int?
  sageConfig Json? // mapping Sage tables → métriques (AUCUN CREDENTIAL)
  selectedProfiles String[] // profils métiers sélectionnés (step 4 onboarding)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Plan d'abonnement (FK vers SubscriptionPlan — null jusqu'à step 1 onboarding)
  planId           String?
  subscriptionPlan SubscriptionPlan? @relation(fields: [planId], references: [id])

  // Relations
  ownerId     String?      @unique
  owner       User?        @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  users       User[]       @relation("UserOrganization")
  dashboards  Dashboard[]
  widgets     Widget[]
  auditLogs   AuditLog[]
  agents      Agent[]
  agentJobs   AgentJob[]
  invitations Invitation[]
  roles       Role[]
  onboardingStatus OnboardingStatus?
  agentLogs        AgentLog[]
  nlqSessions      NlqSession[]
  targets             Target[]
  billingCustomer     BillingCustomer?
  billingSubscription BillingSubscription?
  billingInvoices     BillingInvoice[]
  bugs                Bug[]

  @@map("organizations")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique @db.VarChar(255)
  firstName     String?
  lastName      String?
  passwordHash  String // bcrypt hash
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Auth fields
  hashedRefreshToken   String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  // MULTI-TENANT : CHAQUE USER APPARTIENT À 1 ORG
  organizationId String
  organization   Organization @relation("UserOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  // Owner d'une orga (1 seul)
  ownedOrganization Organization? @relation("OrganizationOwner")

  // Relations
  userRoles  UserRole[]
  dashboards Dashboard[]
  widgets    Widget[]
  auditLogs  AuditLog[]
  invitationsCreated Invitation[] @relation("InvitationsCreated")
  nlqSessions        NlqSession[]
  agentJobs          AgentJob[]
  bugsSubmitted      Bug[]          @relation("BugSubmitter")
  bugsAssigned       Bug[]          @relation("BugAssignee")
  bugComments        BugComment[]

  @@index([organizationId])
  @@map("users")
}

model Invitation {
  id             String       @id @default(uuid())
  email          String       @unique
  firstName      String?
  lastName       String?
  token          String       @unique
  roleId         String
  role           Role         @relation("InvitationRole", fields: [roleId], references: [id])
  expiresAt      DateTime
  isAccepted     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  invitedById    String?
  invitedBy      User?        @relation("InvitationsCreated", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("invitations")
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  permissions RolePermission[]
  users       UserRole[]
  invitations Invitation[]     @relation("InvitationRole")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  action      String // e.g. "read", "write", "manage"
  resource    String // e.g. "users", "dashboards", "all"
  description String?
  roles       RolePermission[]

  createdAt DateTime @default(now())

  @@unique([action, resource])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Dashboard {
  id        String   @id @default(uuid())
  name      String
  layout    Json // [{x,y,w,h,id},...] grid positions
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // MULTI-TENANT
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  widgets Widget[]

  @@index([organizationId])
  @@index([userId])
  @@map("dashboards")
}

model Widget {
  id        String   @id @default(uuid())
  name      String
  type      String // "kpi" | "chart" | "table"
  config    Json // {period: "month", metric: "revenue_mom"}
  exposure  String? // "revenue_mom", "dmp", "ar_aging"
  vizType   String? // "bar", "line", "gauge", "table"
  position  Json // {x:0, y:0, w:4, h:3}
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // MULTI-TENANT
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  dashboardId String?
  dashboard   Dashboard? @relation(fields: [dashboardId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([dashboardId])
  @@map("widgets")
}

model AuditLog {
  id        String   @id @default(uuid())
  event     String // "widget_added", "nlq_executed", "user_login"
  payload   Json // données de l'événement
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // MULTI-TENANT
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)]) // requête principale : logs d'une org triés par date
  @@index([event])                                  // filtre par type d'événement / catégorie
  @@index([userId])
  @@map("audit_logs")
}

model NlqIntent {
  id          String   @id @default(uuid())
  key         String   @unique // ex: "revenue_period"
  label       String   // "Chiffre d'affaires sur une période"
  description String?
  category    String   // "finance" | "commercial" | "treasury"
  keywords    String[] // ["ca", "chiffre affaires", "revenu", "vente"]
  
  templates   NlqTemplate[]
  sessions    NlqSession[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("nlq_intents")
}

model NlqTemplate {
  id             String    @id @default(uuid())
  intentKey      String
  intent         NlqIntent @relation(fields: [intentKey], references: [key], onDelete: Cascade)
  
  sageType       String    // "X3" | "100" (Le SQL change selon l'ERP)
  sqlQuery       String    @db.Text // Template avec placeholders {{database_name}}, $1, etc.
  defaultVizType String    @default("bar") // "bar" | "line" | "gauge" | "card"
  
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([intentKey, sageType])
  @@map("nlq_templates")
}

model NlqSession {
  id             String   @id @default(uuid())
  queryText      String   @db.Text // Texte brut de l'utilisateur
  sqlGenerated   String?  @db.Text
  
  intentKey      String?
  intent         NlqIntent? @relation(fields: [intentKey], references: [key])
  
  status         String   @default("pending") // "pending" | "success" | "error" | "no_intent"
  errorMessage   String?
  latencyMs      Int?
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  jobId          String?  // Relation vers AgentJob pour récupérer le résultat
  
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@map("nlq_sessions")
}

model Agent {
  id         String    @id @default(uuid())
  token      String    @unique // token activation agent
  name       String
  version    String? // version de l'agent installé
  status     String    @default("pending") // "pending" | "online" | "offline" | "error"
  lastSeen   DateTime? // heartbeat
  lastSync   DateTime?
  nextSync   DateTime?
  rowsSynced BigInt    @default(0)
  errorCount Int       @default(0)
  lastError  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Token lifecycle (Section 2.4)
  tokenExpiresAt DateTime? // expiration du token (30j depuis génération)
  isRevoked      Boolean   @default(false) // révocation explicite par l'admin
  revokedAt      DateTime? // timestamp de révocation

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  jobs           AgentJob[]
  agentLogs      AgentLog[]

  @@index([organizationId])
  @@index([token])
  @@map("agents")
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model AgentJob {
  id             String    @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  agentId        String
  agent          Agent     @relation(fields: [agentId], references: [id])
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  sql            String    @db.Text
  status         JobStatus @default(PENDING)
  result         Json?     // Contient les données JSON renvoyées par l'agent
  errorMessage   String?
  
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([organizationId])
  @@index([agentId])
  @@index([userId])
  @@index([status])
  @@map("agent_jobs")
}

// Plans d'abonnement SaaS (gérés dynamiquement par le superadmin)
model SubscriptionPlan {
  id                 String   @id @default(uuid())
  name               String   @unique // "startup" | "pme" | "business" | "enterprise"
  label              String           // "Startup", "PME", "Business", "Enterprise"
  description        String?
  priceMonthly       Float?           // null = sur devis
  isActive           Boolean  @default(true)

  // Limites (null = illimité)
  maxUsers           Int?
  maxKpis            Int?
  maxWidgets         Int?
  maxAgentSyncPerDay Int?
  allowedKpiPacks    String[]
  hasNlq             Boolean  @default(false)
  hasAdvancedReports Boolean  @default(false)

  // Flutterwave — ID du Payment Plan pour souscriptions récurrentes
  fwPlanId           String?  @map("fw_plan_id")

  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organizations        Organization[]
  billingSubscriptions BillingSubscription[]

  @@map("subscription_plans")
}

// Statut du wizard d'onboarding par organisation
model OnboardingStatus {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  currentStep    Int          @default(1)
  completedSteps Int[]        // ex: [1, 2, 3]
  isComplete     Boolean      @default(false)
  inviteLater    Boolean      @default(false) // option "inviter plus tard" step 5
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("onboarding_status")
}

// Définitions des KPIs disponibles (seedées par profil)
model KpiDefinition {
  id               String   @id @default(uuid())
  key              String   @unique  // ex: "f01_ca_ht"
  code             String?           // ex: "KPI-F01"
  name             String
  domain           String?           // ex: "Finance & Trésorerie"
  description      String?
  category         String
  subcategory      String?           // ex: "Revenus"
  usage            String?           // description métier
  unit             String?           // "€", "%", "jours"
  frequency        String?           // ex: "Mensuel / Annuel"
  risk             String?           // "Faible" | "Moyen" | "Élevé"
  profiles         String[]          // ex: ["DAF", "CFO", "DG"]
  sectors          String[]          // ex: ["Tous secteurs"]
  defaultVizType   String            // "gauge" | "bar" | "line" | "table" | "pie" | "map" | "text"
  direction        String   @default("HIGHER_IS_BETTER")
  sqlSage100View   String?           // vue principale Sage 100
  sqlSage100Tables String[]          // tables Sage 100 sous-jacentes
  mlUsage          String?           // usage ML / IA
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  targets          Target[]

  @@map("kpi_definitions")
}

// Templates de visualisation disponibles
model WidgetTemplate {
  id            String   @id @default(uuid())
  name          String   // "KPI Card", "Graphique Barres"
  vizType       String   @unique // "card" | "bar" | "line" | "gauge" | "table"
  description   String?
  defaultConfig Json     // { "period": "month", "aggregation": "sum" }
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@map("widget_templates")
}

// Packs de KPIs par profil métier
model KpiPack {
  id          String   @id @default(uuid())
  name        String   @unique // "pack_daf" | "pack_dg" | "pack_controller"
  label       String   // "Pack DAF", "Pack DG"
  profile     String   // "daf" | "dg" | "controller" | "manager" | "analyst"
  kpiKeys     String[] // ["revenue_mom", "dmp", "ar_aging", "gross_margin", "ebitda"]
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("kpi_packs")
}

model AgentLog {
  id             String       @id @default(uuid())
  level          String       // "info" | "warning" | "error" | "debug"
  message        String       @db.Text
  timestamp      DateTime     @default(now()) // Heure de l'événement côté agent (envoyé via socket)
  createdAt      DateTime     @default(now()) // Heure d'insertion en BDD

  // MULTI-TENANT
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  agentId        String
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([agentId])
  @@index([level])
  @@index([timestamp])
  @@map("agent_logs")
}

// Seed data pour RBAC
model SeedData {
  id   String @id @default(uuid())
  type String // "role_permission" | "nlq_template" | "widget_default"
  data Json
}

// ─── Objectifs / Targets ─────────────────────────────────────────────────────

enum PeriodType {
  MENSUEL    // 12 périodes/an (jan=1 … déc=12)
  BIMESTRE   // 6 périodes/an  (jan-fév=1 … nov-déc=6)
  TRIMESTRE  // 4 périodes/an  (Q1=1 … Q4=4)
  SEMESTRE   // 2 périodes/an  (S1=1, S2=2)
  ANNEE      // 1 période/an   (index=1)
}

enum TargetValueType {
  ABSOLUTE      // Valeur brute dans l'unité native du KPI (ex: 150 000 FCFA, 30 jours)
  PERCENTAGE    // Cible en % absolu (ex: 45 % de marge brute)
  DELTA_PERCENT // Variation relative vs référence (ex: +5 % de croissance)
}

enum DeltaReference {
  PREVIOUS_PERIOD       // vs période N-1 (Q2 2025 → Q1 2025)
  SAME_PERIOD_LAST_YEAR // vs même période N-1 YoY (Q2 2025 → Q2 2024)
}

enum TargetScenario {
  BUDGET    // Budget initial voté
  REVISED   // Budget révisé formellement (mi-année)
  FORECAST  // Prévision glissante (mise à jour en temps réel)
  STRETCH   // Objectif ambitieux "best case"
}

model Target {
  id             String          @id @default(uuid())

  // KPI ciblé
  kpiKey         String
  kpiDefinition  KpiDefinition   @relation(fields: [kpiKey], references: [key], onDelete: Cascade)

  // Valeur de l'objectif
  value          Float
  valueType      TargetValueType @default(ABSOLUTE)
  deltaReference DeltaReference? // Renseigné uniquement si valueType = DELTA_PERCENT

  // Période couverte
  periodType     PeriodType
  periodIndex    Int             // 1-12 (MENSUEL) / 1-6 (BIMESTRE) / 1-4 (TRIMESTRE) / 1-2 (SEMESTRE) / 1 (ANNEE)
  year           Int             // ex: 2025

  // Scénario budgétaire
  scenario       TargetScenario  @default(BUDGET)

  // Note libre
  label          String?         // ex: "Objectif CA Q1 2025 — hypothèse optimiste"

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // MULTI-TENANT
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // 1 seul objectif par org + kpi + période + scénario
  @@unique([organizationId, kpiKey, periodType, periodIndex, year, scenario])
  @@index([organizationId])
  @@index([kpiKey])
  @@index([year])
  @@map("targets")
}

// ─── Billing / Flutterwave ─────────────────────────────────────────────────────

enum BillingStatus {
  TRIALING   // En période d'essai
  ACTIVE     // Abonnement actif et à jour
  PAST_DUE   // Paiement en retard (FW retente)
  CANCELLED  // Abonnement annulé
  UNPAID     // Échec définitif après retentes FW
  PAUSED     // Suspendu manuellement
}

// Client Flutterwave associé à l'organisation (1 org → 1 customer FW)
model BillingCustomer {
  id             String              @id @default(uuid())
  organizationId String              @unique
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fwCustomerId   String?             @unique @map("fw_customer_id") // customer_id retourné par FW webhook
  email          String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  subscription   BillingSubscription?

  @@map("billing_customers")
}

// Abonnement Flutterwave actif de l'organisation
model BillingSubscription {
  id               String           @id @default(uuid())
  organizationId   String           @unique
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId       String           @unique
  customer         BillingCustomer  @relation(fields: [customerId], references: [id])
  fwSubscriptionId String?          @unique @map("fw_subscription_id") // subscription_id retourné par FW
  planId           String
  plan             SubscriptionPlan @relation(fields: [planId], references: [id])
  status           BillingStatus    @default(TRIALING)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean        @default(false) // annulation programmée fin de période
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  invoices         BillingInvoice[]

  @@index([organizationId])
  @@map("billing_subscriptions")
}

// Historique des factures / paiements Flutterwave
model BillingInvoice {
  id              String              @id @default(uuid())
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionId  String
  subscription    BillingSubscription @relation(fields: [subscriptionId], references: [id])
  fwTransactionId String              @unique @map("fw_transaction_id") // transaction_id retourné par FW
  amountPaid      Int                 // en XOF — entier (ex: 36000)
  currency        String              @default("xof")
  status          String              // "paid" | "open" | "failed"
  pdfUrl          String?             // URL reçu PDF (si disponible)
  hostedUrl       String?             // URL page de paiement FW
  paidAt          DateTime?
  createdAt       DateTime            @default(now())

  @@index([organizationId])
  @@index([subscriptionId])
  @@map("billing_invoices")
}

// ─── Configuration système (singleton) ────────────────────────────────────────

model SystemConfig {
  id                      String   @id @default("default")
  notificationPreferences Json?    // { notif: {...}, recipients: [...] }
  updatedAt               DateTime @updatedAt

  @@map("system_config")
}

// ─── Bugs / Task Tracking ─────────────────────────────────────────────────────

model Bug {
  id                String   @id @default(uuid())
  bugId             String   @unique // Format: BR-YYYYMMDD-XXX
  title             String
  bug_type          String[]
  module            String
  priority          String   @default("moyenne") // "critique" | "haute" | "moyenne" | "basse" | "a_analyser"
  severity          Int      @default(3)
  status            String   @default("nouveau") // "nouveau" | "en_analyse" | "en_cours" | "en_test" | "resolu" | "ferme"
  
  // Environment
  url               String?
  browser           String?
  os                String?
  screen            String?
  path              String?
  userAgent         String?
  
  // Business context
  entity_code       String?
  fiscal_year       Int?
  period_start      String?
  period_end        String?
  
  // Details
  description       String   @db.Text
  steps_to_reproduce String[]
  expected_behavior String?  @db.Text
  actual_behavior   String?  @db.Text
  frequency         String   // "toujours" | "souvent" | "parfois" | "une_seule_fois" | "intermittent"
  impact            String   // "production_bloquee", etc.
  users_impacted    String?
  workaround        Boolean  @default(false)
  workaround_desc   String?  @db.Text
  
  // Logs & Attachments
  tags              String[]
  attachments       String[] // URLs (S3)
  console_errors    String?  @db.Text
  
  // Metadata
  notify_emails     String[]
  submittedById     String   @map("submitted_by_id")
  submittedBy       User     @relation("BugSubmitter", fields: [submittedById], references: [id])
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id])
  
  assignedToId      String?  @map("assigned_to_id")
  assignedTo        User?    @relation("BugAssignee", fields: [assignedToId], references: [id])

  comments          BugComment[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@map("bugs")
}

model BugComment {
  id               String   @id @default(uuid())
  bugId            String
  bug              Bug      @relation(fields: [bugId], references: [id], onDelete: Cascade)
  authorId         String
  author           User     @relation(fields: [authorId], references: [id])
  content          String   @db.Text
  isInternal       Boolean  @default(false)
  mentionedUserIds String[] @default([]) // newly added field for tracking mentions
  createdAt        DateTime @default(now())

  @@index([bugId])
  @@map("bug_comments")
}
